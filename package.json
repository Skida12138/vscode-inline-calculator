{
  "name": "vscode-inline-calculator",
  "displayName": "Inline Calculator",
  "repository": "https://github.com/Skida12138/vscode-inline-calculator",
  "description": "A calculator extension with history support.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "inline-calculator.calculate",
        "title": "Inline Calculator: Calculate Expression"
      },
      {
        "command": "inline-calculator.clearHistory",
        "title": "Inline Calculator: Clear History",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "inline-calculator-view-container",
          "title": "Calculator",
          "icon": "resources/calculator.svg"
        }
      ]
    },
    "views": {
      "inline-calculator-view-container": [
        {
          "type": "webview",
          "id": "inline-calculator.history",
          "name": "Calculation History"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "inline-calculator.clearHistory",
          "when": "view == inline-calculator.history",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "inline-calculator.calculate",
        "key": "alt+c",
        "mac": "alt+c"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3",
    "@vscode/test-electron": "^2.3.2"
  },
  "dependencies": {
    "mathjs": "^11.8.0"
  }
}
